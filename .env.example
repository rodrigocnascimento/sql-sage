# sql-sage Database Connection Configuration
# Copy this file to .env and fill in your values.

# Database engine: mysql | mariadb | postgresql | sqlite
SQLSAGE_ENGINE=mysql

# Connection settings
SQLSAGE_HOST=localhost
SQLSAGE_PORT=3306
SQLSAGE_USER=
SQLSAGE_PASSWORD=
SQLSAGE_DATABASE=

# Optional: SSL connection
SQLSAGE_SSL=false

# Optional: Timeout settings (in milliseconds)
SQLSAGE_CONNECT_TIMEOUT=5000
SQLSAGE_QUERY_TIMEOUT=10000
